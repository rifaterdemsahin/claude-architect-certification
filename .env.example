# ==============================================================================
# Claude AI Certification for Architects - Enterprise Environment Configuration
# ==============================================================================

# --- AZURE KEY VAULT CONFIGURATION ---
# Set these if you wish to pull secrets dynamically from Azure Key Vault at runtime.
# If these are not configured, the system will fall back to using the local environment values below.
AZURE_KEYVAULT_NAME="dg-pilot-kv"
AZURE_TENANT_ID="your-azure-tenant-id"
AZURE_CLIENT_ID="your-service-principal-client-id"
AZURE_CLIENT_SECRET="your-service-principal-client-secret"

# 1. Anthropic API Keys (for native API access)
# Obtain from https://console.anthropic.com/
# Key Vault secret key mapping: ANTHROPIC-API-KEY
# Fallback: ANTHROPIC_API_KEY
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# 2. AWS Bedrock Configurations (for enterprise IAM & VPC integration)
# Key Vault secret key mappings:
# - AWS-ACCESS-KEY-ID
# - AWS-SECRET-ACCESS-KEY
# Fallback variables:
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your-aws-access-key-id
AWS_SECRET_ACCESS_KEY=your-aws-secret-access-key
AWS_SESSION_TOKEN=your-aws-session-token-optional
AWS_ROLE_ARN=arn:aws:iam::123456789012:role/ClaudeArchitectVpcAccessRole

# 3. Model Context Protocol (MCP) Server Configuration
PORT=8080
TRANSPORT=sse
MCP_LOG_LEVEL=info
MCP_ENABLE_DEBUG=false

# 4. Zero-Data Retention (ZDR) & Enterprise Auditing
AUDIT_LOG_PATH=./logs/zdr_audit.log
ENFORCE_ZDR_POLICIES=true

# 5. Supabase Configuration (for production pipeline data)
# Project URL: https://supabase.com/dashboard/project/rmekfsdhglyiralxvkwc
# Key Vault secret key mappings:
# - SUPABASE-URL
# - SUPABASE-ANON-KEY
# - SUPABASE-SERVICE-KEY
# Fallback variables:
SUPABASE_URL=https://rmekfsdhglyiralxvkwc.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_KEY=your-service-key-here
