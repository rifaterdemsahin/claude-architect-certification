# ==============================================================================
# Claude AI Certification for Architects - Enterprise Environment Configuration
# ==============================================================================

# 1. Anthropic API Keys (for native API access)
# Obtain from https://console.anthropic.com/
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# 2. AWS Bedrock Configurations (for enterprise IAM & VPC integration)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your-aws-access-key-id
AWS_SECRET_ACCESS_KEY=your-aws-secret-access-key
AWS_SESSION_TOKEN=your-aws-session-token-optional
AWS_ROLE_ARN=arn:aws:iam::123456789012:role/ClaudeArchitectVpcAccessRole

# 3. Model Context Protocol (MCP) Server Configuration
MCP_SERVER_PORT=3000
MCP_LOG_LEVEL=info
MCP_ENABLE_DEBUG=false

# 4. Zero-Data Retention (ZDR) & Enterprise Auditing
AUDIT_LOG_PATH=./logs/zdr_audit.log
ENFORCE_ZDR_POLICIES=true
